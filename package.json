{
  "name": "@renovatebot/osv-offline-monorepo",
  "private": true,
  "type": "module",
  "version": "0.0.0-semantic-release",
  "repository": {
    "type": "git",
    "url": "https://github.com/renovatebot/osv-offline.git"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "eslint": "eslint .",
    "prepare": "husky",
    "prettier": "prettier --cache -c -u \"**/*.*\"",
    "prettier-fix": "prettier --cache -w -u \"**/*.*\"",
    "start": "tsx ./packages/osv-offline-updater/src/index.ts",
    "test": "run-s eslint test:unit test:integration",
    "test:unit": "vitest run unit.spec.ts --outputFile.junit=.coverage/unit.junit.xml",
    "test:integration": "vitest run int.spec.ts --maxWorkers=1 --outputFile.junit=.coverage/integration.junit.xml"
  },
  "devDependencies": {
    "@containerbase/eslint-plugin": "2.1.1",
    "@containerbase/semantic-release-pnpm": "1.4.2",
    "@eslint/js": "10.0.1",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/strictest": "2.0.8",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.19",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-gha": "2.0.1",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-promise": "7.3.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.4",
    "semantic-release": "25.0.5",
    "ts-node": "10.9.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.5.2"
}
